{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EasyScale Legacy Analyzer Blueprint (MVP V2)",
  "description": "Output of the Legacy Analyzer — DNA estruturado de uma clínica extraído de conversas WhatsApp. 1 call LLM, 6 grupos de campos. Consumido por Iris, dashboard, time comercial.",
  "type": "object",
  "required": [
    "metadata",
    "g1_identidade",
    "g2_tom_voz",
    "g3_venda",
    "g4_fluxo",
    "g5_conhecimento",
    "g6_inteligencia_comercial"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["clinic_id", "clinic_name", "generated_at", "analyzer_version", "conversation_count", "message_count"],
      "properties": {
        "clinic_id": { "type": "string", "format": "uuid" },
        "clinic_name": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "analyzer_version": { "type": "string", "examples": ["2.0.0"] },
        "conversation_count": { "type": "integer", "minimum": 0 },
        "message_count": { "type": "integer", "minimum": 0 },
        "llm_provider": { "type": "string", "examples": ["gemini", "openai", "anthropic"] },
        "llm_model": { "type": "string" }
      }
    },

    "g1_identidade": {
      "type": "object",
      "description": "Fatos objetivos da clínica extraídos das conversas.",
      "required": ["clinic_name", "professionals", "services_catalog", "payment_methods"],
      "properties": {
        "clinic_name": { "type": "string", "description": "Nome como aparece nas mensagens." },
        "clinic_address": { "type": ["string", "null"] },
        "clinic_neighborhood": { "type": ["string", "null"] },
        "business_hours": {
          "type": "object",
          "description": "Horário por dia da semana. null = fechado/não mencionado.",
          "properties": {
            "seg": { "type": ["string", "null"] },
            "ter": { "type": ["string", "null"] },
            "qua": { "type": ["string", "null"] },
            "qui": { "type": ["string", "null"] },
            "sex": { "type": ["string", "null"] },
            "sab": { "type": ["string", "null"] },
            "dom": { "type": ["string", "null"] }
          }
        },
        "professionals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["nome"],
            "properties": {
              "nome": { "type": "string" },
              "titulo": { "type": ["string", "null"], "examples": ["Dermatologista", "Biomédica Esteta", "Esteticista"] },
              "especialidades": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "services_catalog": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["nome"],
            "properties": {
              "nome": { "type": "string" },
              "categoria": { "type": ["string", "null"], "examples": ["facial", "corporal", "injetavel", "limpeza"] },
              "duracao_min": { "type": ["integer", "null"] },
              "contraindicacoes_mencionadas": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "service_pricing": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["servico", "valor_or_faixa"],
            "properties": {
              "servico": { "type": "string" },
              "valor_or_faixa": { "type": "string", "description": "Como mencionado: 'R$450', 'a partir de R$1.200', 'R$2.800-3.900'." },
              "condicao": { "type": ["string", "null"], "description": "Ex: 'à vista', 'pacote 3 sessões', 'com sinal'." }
            }
          }
        },
        "payment_methods": {
          "type": "array",
          "items": { "type": "string", "enum": ["pix", "credito", "debito", "dinheiro", "boleto", "transferencia", "wellhub_gympass"] }
        },
        "installments_policy": {
          "type": "object",
          "properties": {
            "aceita": { "type": "boolean" },
            "max_parcelas": { "type": ["integer", "null"] },
            "juros": { "type": ["string", "null"], "examples": ["sem juros", "com juros acima de 6x"] }
          }
        },
        "discounts_policy": {
          "type": "object",
          "properties": {
            "vista_pix": { "type": ["string", "null"], "examples": ["10%", "5%"] },
            "primeira_consulta": { "type": ["string", "null"] },
            "indicacao": { "type": ["string", "null"] },
            "pacote_sessoes": { "type": ["string", "null"] }
          }
        }
      }
    },

    "g2_tom_voz": {
      "type": "object",
      "description": "Como a clínica fala — voz da atendente.",
      "required": ["tom_voz", "nivel_formalidade", "uso_emoji", "comprimento_msg_tipico", "quebra_de_msg", "saudacao_inicial", "despedida_padrao"],
      "properties": {
        "tom_voz": {
          "type": "string",
          "enum": ["formal_clinico", "cordial_amigavel", "marketeiro_alegre", "informal_proximo"]
        },
        "nivel_formalidade": {
          "type": "string",
          "enum": ["voce", "senhor_senhora", "mix"]
        },
        "uso_emoji": {
          "type": "object",
          "required": ["frequencia"],
          "properties": {
            "frequencia": { "type": "string", "enum": ["alta", "media", "baixa", "zero"] },
            "tipos_comuns": { "type": "array", "items": { "type": "string" } }
          }
        },
        "comprimento_msg_tipico": {
          "type": "string",
          "enum": ["curto_objetivo", "medio_explicativo", "longo_caloroso"]
        },
        "quebra_de_msg": {
          "type": "string",
          "enum": ["uma_msg_longa", "varias_msgs_curtas", "mix"]
        },
        "saudacao_inicial": {
          "type": "array",
          "description": "3-5 exemplos reais de aberturas extraídas.",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 8
        },
        "despedida_padrao": {
          "type": "array",
          "description": "3-5 exemplos reais de fechamentos.",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 8
        }
      }
    },

    "g3_venda": {
      "type": "object",
      "description": "Como a clínica vende.",
      "required": ["politica_preco", "momento_revela_preco", "educacao_tecnica", "prova_social_uso", "mencao_profissional", "politica_sinal", "objecoes_recorrentes", "contraindicacao_policy"],
      "properties": {
        "politica_preco": {
          "type": "string",
          "enum": ["aberto", "faixa", "avaliacao", "sinal", "mix"]
        },
        "momento_revela_preco": {
          "type": "string",
          "enum": ["imediato", "apos_qualificacao", "apos_anamnese", "so_avaliacao"]
        },
        "educacao_tecnica": {
          "type": "string",
          "enum": ["explica_no_zap", "mix", "guarda_pra_avaliacao"]
        },
        "qualificacao_tipica": {
          "type": "array",
          "description": "Perguntas de qualificação observadas ao paciente.",
          "items": { "type": "string" }
        },
        "prova_social_uso": {
          "type": "string",
          "enum": ["proativa_antes_depois", "sob_demanda", "nao_usa"]
        },
        "mencao_profissional": {
          "type": "string",
          "enum": ["nomeia_dermato", "nomeia_biomedica", "nao_nomeia", "por_servico"]
        },
        "politica_sinal": {
          "type": "object",
          "required": ["usa_sinal"],
          "properties": {
            "usa_sinal": { "type": "boolean" },
            "valor_ou_percentual": { "type": ["string", "null"], "examples": ["R$ 50", "R$ 100", "20%"] },
            "momento": { "type": ["string", "null"], "examples": ["pra reservar", "no dia"] },
            "abatimento": { "type": ["string", "null"], "examples": ["abate no dia", "não abate"] }
          }
        },
        "objecoes_recorrentes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["objecao", "resposta_padrao_da_clinica"],
            "properties": {
              "objecao": { "type": "string" },
              "resposta_padrao_da_clinica": { "type": "string" }
            }
          }
        },
        "contraindicacao_policy": {
          "type": "object",
          "required": ["deteccao", "acao"],
          "properties": {
            "deteccao": { "type": "string", "enum": ["triagem_estruturada", "triagem_leve", "so_avaliacao", "nao_aborda"] },
            "acao": { "type": "string", "enum": ["escala_avaliacao", "orienta_e_marca", "marca_direto", "recusa_atender"] }
          }
        }
      }
    },

    "g4_fluxo": {
      "type": "object",
      "description": "Como a clínica navega a conversa.",
      "required": ["fluxo_padrao_atendimento", "como_confirma_agendamento", "follow_up_apos_silencio"],
      "properties": {
        "fluxo_padrao_atendimento": {
          "type": "array",
          "description": "Sequência ordenada de etapas observada.",
          "items": {
            "type": "string",
            "enum": ["greeting", "qualifica_area", "qualifica_objetivo", "educa", "preco", "agenda", "sinal", "confirmacao", "follow_up", "escala_humano"]
          }
        },
        "como_confirma_agendamento": { "type": "string", "description": "Texto-modelo extraído de uma confirmação real." },
        "follow_up_apos_silencio": {
          "type": "object",
          "required": ["tenta_quantas_vezes"],
          "properties": {
            "tenta_quantas_vezes": { "type": "integer", "minimum": 0 },
            "intervalo_horas": { "type": ["number", "null"] },
            "tom": { "type": ["string", "null"], "examples": ["leve_curioso", "direto", "carinhoso", "profissional"] }
          }
        }
      }
    },

    "g5_conhecimento": {
      "type": "object",
      "description": "FAQ + repertório operacional da clínica.",
      "required": ["faq_extraido", "procedimentos_explicados", "casos_de_escalation"],
      "properties": {
        "faq_extraido": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pergunta_padrao", "resposta_padrao_da_clinica"],
            "properties": {
              "pergunta_padrao": { "type": "string" },
              "resposta_padrao_da_clinica": { "type": "string" }
            }
          }
        },
        "procedimentos_explicados": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["procedimento", "explicacao"],
            "properties": {
              "procedimento": { "type": "string" },
              "explicacao": { "type": "string" },
              "beneficios_destacados": { "type": "array", "items": { "type": "string" } },
              "contraindicacoes_mencionadas": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "casos_de_escalation": {
          "type": "array",
          "description": "Gatilhos que sempre escalam pra humano.",
          "items": { "type": "string" }
        }
      }
    },

    "g6_inteligencia_comercial": {
      "type": "object",
      "description": "Sinais comerciais agregados.",
      "required": ["origem_paciente_distribuicao"],
      "properties": {
        "origem_paciente_distribuicao": {
          "type": "object",
          "description": "Percentual aproximado por canal de origem (0-100).",
          "properties": {
            "google_ads": { "type": "number", "minimum": 0, "maximum": 100 },
            "instagram": { "type": "number", "minimum": 0, "maximum": 100 },
            "indicacao": { "type": "number", "minimum": 0, "maximum": 100 },
            "google_organico": { "type": "number", "minimum": 0, "maximum": 100 },
            "retorno": { "type": "number", "minimum": 0, "maximum": 100 },
            "outros": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      }
    }
  }
}
